<div class="max-w-7xl mx-auto">
  <%= render 'backoffice/reports/shared/report_header',
      title: "Vendas Detalhadas" %>

  <!-- Filtro de Período -->
  <%= render 'backoffice/reports/shared/period_filter',
      current_period: @period,
      base_path: sales_detail_backoffice_reports_path(customer_id: @customer_id) %>

  <!-- Filtro de Cliente -->
  <%= render 'shared/ui/card', class: "mb-6" do %>
    <%= form_with url: sales_detail_backoffice_reports_path, method: :get, local: true, class: "flex flex-col gap-2" do |f| %>
      <%= f.hidden_field :period, value: @period %>
      <label for="customer_id" class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
        Cliente
      </label>
      <select name="customer_id" id="customer_id" onchange="this.form.submit()"
              class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-[#0e1b12] dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent">
        <option value="" <%= @customer_id.blank? ? 'selected' : '' %>>Todos os clientes</option>
        <% @customers.each do |customer| %>
          <option value="<%= customer.id %>" <%= @customer_id.to_s == customer.id.to_s ? 'selected' : '' %>><%= customer.name %></option>
        <% end %>
      </select>
    <% end %>
  <% end %>

  <!-- Cards de totais -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <%= render 'shared/ui/metric_card',
        label: "TOTAL DAS VENDAS",
        value: @total_sales.to_f,
        value_type: :currency %>

    <%= render 'shared/ui/metric_card',
        label: "TOTAL DE DESCONTOS",
        value: @total_discounts.to_f,
        value_type: :currency %>
  </div>

  <!-- Lista de vendas -->
  <%= render 'shared/ui/card', class: "mb-6" do %>
    <%= render 'shared/ui/heading',
        text: "Vendas no período",
        size: :lg,
        class: "mb-4" %>

    <% if @sales.any? %>
      <div class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @sales.each do |sale| %>
          <div class="py-4 first:pt-0 last:pb-0">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-[#0e1b12] dark:text-white">
                  #<%= sale.sale_number %>
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  <%= sale.created_at.strftime("%d/%m/%Y às %H:%M") %>
                  <% if sale.customer.present? %>
                    • <%= sale.customer.name %>
                  <% else %>
                    • —
                  <% end %>
                </p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  Subtotal: <%= number_to_currency(sale.subtotal, unit: "R$ ", separator: ",", delimiter: ".") %>
                  <% if sale.discount_amount.to_f.positive? %>
                    • Desconto: -<%= number_to_currency(sale.discount_amount, unit: "R$ ", separator: ",", delimiter: ".") %>
                  <% end %>
                </p>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                <p class="text-lg font-bold" style="color: var(--color-primary);">
                  <%= number_to_currency(sale.total_amount, unit: "R$ ", separator: ",", delimiter: ".") %>
                </p>
                <%= link_to backoffice_sale_path(sale),
                    class: "inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline",
                    style: "color: var(--color-primary);" do %>
                  Ver
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400 py-4">
        Nenhuma venda encontrada no período<%= @customer_id.present? ? " para este cliente" : "" %>.
      </p>
    <% end %>
  <% end %>
</div>
